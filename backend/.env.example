# 이 파일을 복사해서 .env로 만들고 실제 값을 채워넣으세요.
# .env는 절대 Git에 올리지 않습니다 (Git 가이드라인 8번 규칙).
 
# PostgreSQL 접속 정보
DATABASE_URL=postgresql+psycopg://disaster_user:local_dev_password@localhost:5432/disaster_db
 
# JWT 토큰 서명용 비밀키 (아무 랜덤 문자열, 아래 명령으로 생성 가능)
# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=temp_secret_key_for_dev
 
# Access Token 만료 시간(분), Refresh Token 만료 시간(일)
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
 
# 프론트엔드 개발 서버 주소 (CORS 허용용)
FRONTEND_ORIGIN=http://localhost:5173